# ── Google OAuth ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override Gemini model priority (comma-separated) ───────────────
# GEMINI_MODEL_LIST=gemini-2.0-flash,gemini-2.5-flash-lite

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with__openssl_rand_-base64_32

# ── Database (SQLite — do not change for local development) ──────────────────
DATABASE_URL=file:./dev.db
