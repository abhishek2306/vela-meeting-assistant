# Copy this file to .env.local and fill in your values.
# Run: cp .env.local.example .env.local
#
# ⚠️  IMPORTANT: .env.local is in .gitignore and must NEVER be committed to Git.

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
# Use an AI Studio key (not a Cloud Console key) for proper free-tier quotas.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the Gemini model priority list (comma-separated)
# GEMINI_MODEL_LIST=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Must match the URL where your app runs
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_strong_random_secret

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local development) — do not change unless deploying
DATABASE_URL="file:./dev.db"
